ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_MAPS_API_KEY=AIza...
TRIPADVISOR_API_KEY=...

# Google OAuth — paste the full JSON contents of credentials.json
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...",...}}

# Set after first OAuth login on Railway — paste the full contents of token.json
GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# Set to your Railway app URL
REDIRECT_URI=https://your-app.railway.app/api/auth/callback
